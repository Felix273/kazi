# ─── Kazi Backend — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Django
SECRET_KEY=your-long-random-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database (PostgreSQL + PostGIS)
DB_NAME=kazi_db
DB_USER=postgres
DB_PASSWORD=your-db-password-here
DB_HOST=localhost
DB_PORT=5432

# Redis (for Django Channels WebSocket layer)
REDIS_URL=redis://localhost:6379

# Africa's Talking (OTP SMS)
# Sign up at: https://africastalking.com
# Use 'sandbox' username for testing — real SMS won't send but logs will show codes
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=your-africastalking-api-key-here
AFRICASTALKING_SENDER_ID=KAZI

# IntaSend (M-Pesa payments)
# Sign up at: https://intasend.com
# Use test mode first — no real money moves
INTASEND_PUBLIC_KEY=your-intasend-public-key-here
INTASEND_SECRET_KEY=your-intasend-secret-key-here
INTASEND_TEST_MODE=True

# Smile Identity (KYC / ID verification)
# Sign up at: https://smileidentity.com
# Free sandbox available immediately
SMILE_IDENTITY_PARTNER_ID=your-smile-partner-id-here
SMILE_IDENTITY_API_KEY=your-smile-api-key-here

# Firebase (Push notifications)
# Create project at: https://console.firebase.google.com
# Get Server Key from Project Settings > Cloud Messaging
FIREBASE_SERVER_KEY=your-firebase-server-key-here

# Your backend's public URL (used for IntaSend webhook callbacks)
# In development use ngrok: https://ngrok.com
BACKEND_URL=https://your-ngrok-or-production-url.com